# OpenRouter AI
OPENROUTER_API_KEY=your_openrouter_key
OPENROUTER_MODEL=google/gemini-2.0-flash-001
DEBUG_BRAND=0

# App
JWT_SECRET=replace_with_long_random_secret
# URL pubblico canonico (es. https://pcto-nextjs.vercel.app) — deve coincidere col dominio usato dagli utenti
APP_URL=http://localhost:3000
# Solo sviluppo locale (npm run dev). In production non ha effetto.
# BILLING_ALLOW_SANDBOX=1

# Stripe (live o test)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
# Price ID (price_...) oppure Product ID (prod_...) — se usi prod_, l'app crea il prezzo mensile
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_GROWTH=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx

# Database (persistence layer)
# firestore = default | mongodb = stub (da implementare in lib/db/providers/mongodb.ts)
DATABASE_PROVIDER=firestore
# MONGODB_URI=mongodb+srv://user:pass@cluster/dbname

# Firebase client
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase admin (scegli una opzione)
FIREBASE_SERVICE_ACCOUNT_JSON=
# oppure:
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Sentry (org: rovizz-apps, project: quotegen-engine)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
