# ─────────────────────────────────────────────────────────────────────────────
# QuoteGen Engine — Environment variables
# Copy to .env.local for local development. Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
# URL pubblico canonico (es. https://pcto-nextjs.vercel.app) — deve coincidere
# col dominio usato dagli utenti e nelle redirect Stripe.
APP_URL=http://localhost:3000

# Segreto JWT per le sessioni utente (minimo 64 caratteri casuali).
# Genera con: openssl rand -hex 32
JWT_SECRET=replace_with_at_least_64_char_random_secret

# ── Admin Backoffice ──────────────────────────────────────────────────────────
# OBBLIGATORIO in produzione. L'app rifiuta il login admin se mancanti.
ADMIN_EMAIL=your_admin@example.com
ADMIN_PASSWORD=your_strong_admin_password
# Segreto per firmare i JWT admin (minimo 32 caratteri casuali).
# Genera con: openssl rand -hex 16
ADMIN_SECRET_KEY=replace_with_at_least_32_char_random_secret

# ── OpenRouter AI ─────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_key
# gemini-2.0-flash-001 ritirato 2026-06-01 — usa 2.5+ o openai/gpt-4o-mini
OPENROUTER_MODEL=google/gemini-2.5-flash
DEBUG_BRAND=0

# ── Stripe ────────────────────────────────────────────────────────────────────
# Usa chiavi test (sk_test_...) in sviluppo, live (sk_live_...) in produzione.
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
# Price ID (price_...) oppure Product ID (prod_...) per ogni piano.
STRIPE_PRICE_STARTER=price_xxx
STRIPE_PRICE_GROWTH=price_xxx
STRIPE_PRICE_ENTERPRISE=price_xxx
# Solo sviluppo locale — abilita pagamenti sandbox senza Stripe reale.
# BILLING_ALLOW_SANDBOX=1

# ── Database ──────────────────────────────────────────────────────────────────
# firestore = default (implementato) | mongodb = stub (non ancora implementato)
DATABASE_PROVIDER=firestore
# MONGODB_URI=mongodb+srv://user:pass@cluster/dbname

# ── Firebase client (variabili pubbliche Next.js) ────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin (server-side) — scegli una delle due opzioni ──────────────
# Opzione A: JSON completo del service account
FIREBASE_SERVICE_ACCOUNT_JSON=
# Opzione B: variabili separate
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Ottieni la chiave su https://resend.com — piano free: 3000 email/mese
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# Dominio mittente (richiede verifica DNS su Resend, oppure usa onboarding@resend.dev in test)
RESEND_FROM_DOMAIN=noreply@tuodominio.com

# ── Cron ──────────────────────────────────────────────────────────────────────
# Segreto per proteggere il cron endpoint da chiamate non autorizzate
# Genera con: openssl rand -hex 16
CRON_SECRET=replace_with_random_secret

# ── Sentry ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
